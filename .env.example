# Database Configuration
DATABASE_URL="postgresql://username:password@localhost:5432/nata_group_monitoring"

# NextAuth Configuration
NEXTAUTH_SECRET="your-secret-key-here-min-32-characters"
NEXTAUTH_URL="http://localhost:3000"

# JWT Configuration
JWT_SECRET="your-jwt-secret-key-here"
JWT_EXPIRATION="7d"

# Socket.io Configuration (for real-time updates)
SOCKET_IO_SERVER_URL="http://localhost:3000"

# Application Configuration
NODE_ENV="development"
NEXT_PUBLIC_APP_NAME="Nata Group Monitoring"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# File Upload Configuration
MAX_FILE_SIZE_MB=50
ALLOWED_FILE_TYPES="pdf,xlsx,xls,doc,docx,jpg,jpeg,png,gif"

# Email Configuration (optional)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your-email@gmail.com"
SMTP_PASSWORD="your-app-password"
SMTP_FROM="noreply@natagroup.com"

# Logging & Monitoring
LOG_LEVEL="info"
SENTRY_DSN=""

# Feature Flags
ENABLE_REAL_TIME_UPDATES="true"
ENABLE_ANALYTICS="true"
ENABLE_DOCUMENT_UPLOAD="true"
